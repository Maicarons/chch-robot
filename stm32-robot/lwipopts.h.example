/**
 * lwipopts.h - LwIP配置文件示例
 * 
 * 根据实际硬件调整参数
 */

#ifndef __LWIPOPTS_H__
#define __LWIPOPTS_H__

/* ==================== 系统相关 ==================== */

/* 使用STM32 HAL库 */
#define NO_SYS                      0
#define SYS_LIGHTWEIGHT_PROT        1

/* 内存管理 */
#define MEM_ALIGNMENT               4
#define MEM_SIZE                    (4 * 1024)  // 4KB RAM

/* ==================== TCP选项 ==================== */

#define LWIP_TCP                    1
#define TCP_TTL                     255

/* 流量控制 */
#define TCP_WND                     (4 * TCP_MSS)
#define TCP_SND_BUF                 (4 * TCP_MSS)
#define TCP_SND_QUEUELEN            ((4 * (TCP_SND_BUF) + (TCP_MSS - 1))/(TCP_MSS))

/* MSS大小 */
#define TCP_MSS                     1460

/* TCP选项 */
#define TCP_KEEPALIVE               1
#define TCP_KEEPIDLE_DEFAULT        60000   // 60秒
#define TCP_KEEPINTVL_DEFAULT       10000   // 10秒
#define TCP_KEEPCNT_DEFAULT         5

/* ==================== DHCP选项 ==================== */

/* 如果需要DHCP，启用以下选项 */
// #define LWIP_DHCP                   1
// #define LWIP_DNS                    1

/* ==================== ICMP选项 ==================== */

#define LWIP_ICMP                   1
#define LWIP_BROADCAST_PING         1
#define LWIP_MULTICAST_PING         1

/* ==================== UDP选项 ==================== */

#define LWIP_UDP                    1
#define LWIP_UDPLITE                1

/* ==================== DNS选项 ==================== */

// #define LWIP_DNS                    1

/* ==================== 调试选项 ==================== */

/* 生产环境关闭调试 */
#define LWIP_DEBUG                  0

